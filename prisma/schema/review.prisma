model Rating {
    id        String @id @default(cuid())
    userId    String
    contentId String
    value     Int // 1-10

    content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@unique([userId, contentId])
    @@index([contentId])
}

model Review {
    id        String @id @default(cuid())
    userId    String
    contentId String
    comment   String
    rating    Int?

    content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([contentId])
}
