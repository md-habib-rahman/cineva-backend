model Content {
    id          String  @id @default(cuid())
    title       String
    
    description String?

    type       ContentType
    accessType AccessType  @default(AVOD)

    posterUrl    String?
    backdropUrl  String?
    thumbnailUrl String?

    language  String?
    country   String?
    ageRating String?

    releaseDate DateTime?
    

    isPublished Boolean   @default(false)
    publishedAt DateTime?

    avgRating    Float @default(0)
    totalRatings Int   @default(0)

    genres  ContentGenre[]
    cast    ContentCast[]
    ratings Rating[]
    reviews Review[]
    liveTv  LiveTv?
    series  Series?
    movie   Movie?
    drama   Drama?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([type])
    @@index([accessType])
    @@index([isPublished])
}


