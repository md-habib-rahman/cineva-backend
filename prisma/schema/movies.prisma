model Movie {
    id        String @id @default(cuid())
    contentId String @unique

    director  String?
    writers   String?
    producers String?

    videoUrl   String
    trailerUrl String?
    duration   Int?

    content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([contentId])
}
